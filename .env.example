# ─── DivulgeAI Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to git.

# Your backend API base URL (leave empty to use localStorage mock)
# Example: https://api.divulgeai.com
VITE_API_URL=

# Anthropic API key (only needed for direct browser → Claude calls in dev)
# In production, call Claude from your backend and never expose this key.
VITE_ANTHROPIC_KEY=your_anthropic_api_key_here
